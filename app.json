{
  "expo": {
    "name": "Iris",
    "slug": "iris-mobile",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/iris/icons/icon.png",
    "scheme": "iris",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yarreddirector.irismobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.yarreddirector.iris",

      // ✅ aby klávesnica nezakrývala input
      "softwareKeyboardLayoutMode": "resize",

      // ✅ deep link pre Supabase magic link
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "iris",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },

    // ✅ JEDEN splash – žiadne preblikávanie
    "splash": {
      "image": "./assets/images/iris/icons/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",

      // ✅ nech splash riadiš TY (a nie Expo auto-hide)
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/iris/icons/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#000000"
        }
      ],

      // ✅ nutné pre Supabase session persistence
      "expo-secure-store"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "eas": {
        "projectId": "9dbe6907-e6c8-4426-b3a6-60e116fe1b10"
      }
    }
  }
}
